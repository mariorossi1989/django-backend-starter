# Backend Environment Configuration Template
# Copy this file to .env and fill in your actual values
# Note: .env is in .gitignore and should never be committed

# ============================================================================
# Environment State
# ============================================================================
# development: Local development with debug enabled
# production: Production environment with security hardening
ENV_STATE="development"

# ============================================================================
# Django Settings
# ============================================================================
# Django secret key - use a strong, random value in production
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY="your-secret-key-here-change-in-production"

# Debug mode - should be False in production
DJANGO_DEBUG="True"

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection settings
DATABASE_ENGINE="postgresql"
DATABASE_NAME="backend_db"
DATABASE_USER="dev_user"
DATABASE_PASSWORD="dev_password"
DATABASE_HOST="localhost"
DATABASE_PORT="5432"

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Development: DEBUG (verbose output)
# Production: INFO or WARNING (reduce noise)
LOG_LEVEL="DEBUG"

# Directory for log files (development: console-only, production: file-based)
LOG_DIR="logs"
